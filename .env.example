# Auth0
AUTH0_SECRET=replace_with_a_32_byte_hex_secret
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=replace_with_auth0_client_id
AUTH0_CLIENT_SECRET=replace_with_auth0_client_secret

# Google Gemini
GOOGLE_GEMINI_API_KEY=replace_with_gemini_api_key
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# Solana Devnet reward sender
# Use a JSON array secret key from a funded devnet wallet, e.g. [12,34,...]
SOLANA_REWARD_SECRET_KEY=[replace_with_64_byte_secret_key_array]
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional default recipient when user does not provide a wallet
DEFAULT_REWARD_WALLET=

# Database (production: Neon/Vercel Postgres)
# In Vercel, set either POSTGRES_URL or DATABASE_URL
POSTGRES_URL=
DATABASE_URL=
Supabase direct example:
DATABASE_URL=postgresql://postgres:160803@ZuErO...@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Supabase client (optional, only if you later use supabase-js on frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
